# ZenMux API 配置
ZENMUX_API_KEY=sk-ai-v1-your-api-key-here

# 默认模型 (例如: openai/gpt-4o, anthropic/claude-sonnet-4-20250514, google/gemini-2.5-flash)
ZENMUX_DEFAULT_MODEL=openai/gpt-4o

# 你的站点 URL (可选, 用于在 ZenMux 上标识你的应用)
ZENMUX_SITE_URL=http://localhost:3000

# 你的应用名称 (可选)
ZENMUX_SITE_NAME=ZenMux-Demo
